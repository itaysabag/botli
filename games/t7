// ══════════════════════════════════════════════════════
// PIN POSITIONS [leftPct, topPct]
// ══════════════════════════════════════════════════════
const PIN_POS = [
  [12, 72],  // שער הכניסה
  [30, 52],  // גשר העצים
  [22, 28],  // תוכי העתיק
  [52, 18],  // נהר הפתלתן
  [70, 44],  // מחנה האבוד
  [85, 18],  // כיכר ההצלה
];

const LOC_NAMES = ['gate','bridge','parrot','river','camp','rescue'];

// ══════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════
let completed    = new Set();
let usedIndexes  = {};  // {locName: Set of used question indexes}
let lives        = 3;
let wrongs       = 0;
let startTime    = null;
let timerInt     = null;
let timerLeft    = 0;
let timerTotal   = 0;
let curIdx       = null;   // which location is open
let curQ         = null;   // the chosen question object
let modalLocked  = false;
let dragSrc      = null;

// ══════════════════════════════════════════════════════
// BOOT
// ══════════════════════════════════════════════════════
LOC_NAMES.forEach(n => usedIndexes[n] = new Set());

// ══════════════════════════════════════════════════════
// START
// ══════════════════════════════════════════════════════
function startGame(){
  startTime = Date.now();
  document.getElementById('s-intro').classList.add('hidden');
  document.getElementById('tp').style.display = 'flex';
  positionPins();
  refreshPins();
  buildPaths();
}

// ══════════════════════════════════════════════════════
// PIN POSITIONING
// ══════════════════════════════════════════════════════
function positionPins(){
  PIN_POS.forEach(([lp,tp], i)=>{
    const el = document.getElementById(`pin-${i}`);
    if(el){ el.style.left=lp+'%'; el.style.top=tp+'%'; }
  });
}

function refreshPins(){
  buildLives();
  updateProgress();
  for(let i=0;i<6;i++){
    const pin=document.getElementById(`pin-${i}`);
    const bub=document.getElementById(`bubble-${i}`);
    if(!pin||!bub) continue;
    // remove badges
    bub.querySelectorAll('.done-badge,.lock-badge').forEach(e=>e.remove());
    pin.classList.remove('locked','available','done','current');
    if(completed.has(i)){
      pin.classList.add('done');
      const b=document.createElement('span');b.className='done-badge';b.textContent='✓';bub.appendChild(b);
    } else if(i===0||completed.has(i-1)){
      pin.classList.add('available');
    } else {
      pin.classList.add('locked');
      const b=document.createElement('span');b.className='lock-badge';b.textContent='🔒';bub.appendChild(b);
    }
  }
}

function buildLives(){
  const row=document.getElementById('hud-lives');
  row.innerHTML='';
  for(let i=0;i<3;i++){
    const s=document.createElement('span');
    s.className='life'+(i>=lives?' lost':'');
    s.textContent='❤️';row.appendChild(s);
  }
}

function updateProgress(){
  const p=Math.round(completed.size/6*100);
  document.getElementById('hud-prog').style.width=p+'%';
  document.getElementById('hud-pct').textContent=p+'%';
}

function buildPaths(){
  const svg=document.getElementById('map-svg');
  svg.innerHTML='';
  const W=window.innerWidth, H=window.innerHeight;
  for(let i=0;i<PIN_POS.length-1;i++){
    const [l1,t1]=PIN_POS[i],[l2,t2]=PIN_POS[i+1];
    const x1=W*l1/100, y1=H*t1/100;
    const x2=W*l2/100, y2=H*t2/100;
    const cx=(x1+x2)/2, cy=Math.min(y1,y2)-40;
    const path=document.createElementNS('http://www.w3.org/2000/svg','path');
    path.setAttribute('d',`M${x1},${y1} Q${cx},${cy} ${x2},${y2}`);
    path.setAttribute('class',completed.has(i)?'map-path map-path-done':'map-path');
    svg.appendChild(path);
  }
}

window.addEventListener('resize',()=>{
  positionPins();buildPaths();
});

// ══════════════════════════════════════════════════════
// PIN CLICK
// ══════════════════════════════════════════════════════
function clickPin(idx){
  const pin=document.getElementById(`pin-${idx}`);
  if(pin.classList.contains('locked')){showToast('🔒 פתרו קודם את האתגר הקודם!');return;}
  if(pin.classList.contains('done')){showToast('✅ כבר פתרתם את האתגר הזה!');return;}
  openChallenge(idx);
}

// ══════════════════════════════════════════════════════
// PICK QUESTION (no repeats)
// ══════════════════════════════════════════════════════
function pickQuestion(locIdx){
  const name=LOC_NAMES[locIdx];
  const pool=DB[name];
  const used=usedIndexes[name];
  // if all used, reset
  if(used.size>=pool.length) used.clear();
  let qi;
  do{ qi=Math.floor(Math.random()*pool.length); }while(used.has(qi));
  used.add(qi);
  return pool[qi];
}

// ══════════════════════════════════════════════════════
// OPEN CHALLENGE
// ══════════════════════════════════════════════════════
function openChallenge(idx){
  curIdx=idx;
  curQ=pickQuestion(idx);
  modalLocked=false;
  renderModal(curQ);
  document.getElementById('modal').classList.add('open');
}

function closeModal(){
  if(modalLocked) return;
  clearTimer();
  document.getElementById('modal').classList.remove('open');
}

function closeModalOutside(e){
  if(e.target===document.getElementById('modal')) closeModal();
}
document.getElementById('modal').addEventListener('click', closeModalOutside);

// ══════════════════════════════════════════════════════
// RENDER MODAL
// ══════════════════════════════════════════════════════
function renderModal(q){
  clearTimer();
  const title = ['שער הכניסה','גשר העצים','תוכי העתיק','נהר הפתלתן','מחנה האבוד','כיכר ההצלה'][curIdx];

  let html=``;
  if(q.timerSec){
    html+=`<div class="modal-timer-display show" id="tmr-disp"><span>⏱️</span><span class="timer-num ok" id="tmr-num">--:--</span></div>`;
  }
  html+=`
    <span class="ch-icon">${q.icon}</span>
    <div class="ch-type">${q.type_tag}</div>
    <div class="ch-title">${title}</div>
    <div class="ch-desc">${q.desc}</div>
    <div class="hint-box" id="hint-box">💡 ${q.hint}</div>
  `;

  if(q.kind==='code') html+=buildCodeHTML(q);
  else if(q.kind==='choice') html+=buildChoicesHTML(q.choices);
  else if(q.kind==='order'){ html+=buildOrderHTML(q); }
  else if(q.kind==='text') html+=buildTextHTML();
  else if(q.kind==='clues_choice') html+=buildCluesChoiceHTML(q);

  html+=`<div class="feedback" id="fb"></div>
    <div class="action-row" id="act-row">`;
  if(q.kind==='order') html+=`<button class="btn btn-green" onclick="checkOrder()">✅ בדוק סדר</button>`;
  html+=`<button class="btn btn-ghost" onclick="toggleHint()">💡 רמז</button></div>`;

  document.getElementById('modal-body').innerHTML=html;

  // wire up drag
  if(q.kind==='order') wireDrag();

  // timer bar
  const tf=document.getElementById('topbar-fill');
  tf.style.transition='none';tf.style.width='100%';
  if(q.timerSec){
    setTimeout(()=>{ tf.style.transition=`width ${q.timerSec}s linear`; tf.style.width='0%'; },50);
    startTimer(q.timerSec);
  }
}

// ── HTML builders ──
function buildCodeHTML(q){
  const len=q.codeLen||1;
  let boxes='';
  for(let i=0;i<len;i++)
    boxes+=`<input class="code-box" id="cb${i}" maxlength="1" inputmode="numeric"
      oninput="cbInput(this,${i},${len})" onkeydown="cbBack(event,${i})" autocomplete="off"/>`;
  return `<div class="code-row">${boxes}</div>
    <div class="action-row" style="margin-bottom:12px">
      <button class="btn btn-green" onclick="checkCode()">✅ בדוק קוד</button></div>`;
}

function buildChoicesHTML(choices){
  return `<div class="choices">${choices.map((c,i)=>
    `<button class="choice-btn" id="ch${i}" onclick="checkChoice(${i})">${c}</button>`).join('')}</div>`;
}

function buildOrderHTML(q){
  // shuffle items for display
  const shuffled=[...q.items].sort(()=>Math.random()-0.5);
  return `<div class="order-list" id="ord-list">${shuffled.map((it,i)=>`
    <div class="order-item" id="oi-${it.id}" draggable="true" data-id="${it.id}">
      <span class="drag-handle">⠿</span>
      <span class="ord-num">${i+1}</span>
      <span>${it.text}</span>
    </div>`).join('')}</div>`;
}

function buildTextHTML(){
  return `<div class="text-wrap">
    <input class="text-ans" id="ta" type="text" placeholder="כתבו תשובה כאן..."
      autocomplete="off" onkeydown="if(event.key==='Enter')checkText()"/>
    <button class="btn btn-green" onclick="checkText()">✅</button>
  </div>`;
}

function buildCluesChoiceHTML(q){
  const clues=q.clues.map((c,i)=>`
    <div class="clue-item">
      <div class="clue-n">${i+1}</div>
      <div class="clue-t">${c}</div>
    </div>`).join('');
  return `<div class="clues-list">${clues}</div>${buildChoicesHTML(q.choices)}`;
}

// ── input helpers ──
function cbInput(el,idx,len){
  el.value=el.value.replace(/[^0-9]/g,'').slice(-1);
  if(el.value&&idx<len-1){ const n=document.getElementById(`cb${idx+1}`); if(n) n.focus(); }
}
function cbBack(e,idx){
  if(e.key==='Backspace'&&!e.target.value&&idx>0){
    const p=document.getElementById(`cb${idx-1}`); if(p){p.focus();p.value='';}
  }
}

function wireDrag(){
  const list=document.getElementById('ord-list');
  if(!list) return;
  list.querySelectorAll('.order-item').forEach(item=>{
    item.addEventListener('dragstart',()=>{dragSrc=item;item.classList.add('dragging');});
    item.addEventListener('dragend',()=>{item.classList.remove('dragging');dragSrc=null;reNumOrder();});
    item.addEventListener('dragover',e=>{e.preventDefault();item.classList.add('drag-over');});
    item.addEventListener('dragleave',()=>item.classList.remove('drag-over'));
    item.addEventListener('drop',e=>{
      e.preventDefault();item.classList.remove('drag-over');
      if(dragSrc&&dragSrc!==item){
        const all=[...list.querySelectorAll('.order-item')];
        const si=all.indexOf(dragSrc),ti=all.indexOf(item);
        if(si<ti) list.insertBefore(dragSrc,item.nextSibling);
        else list.insertBefore(dragSrc,item);
        reNumOrder();
      }
    });
  });
}
function reNumOrder(){
  document.querySelectorAll('.order-item').forEach((el,i)=>{
    el.querySelector('.ord-num').textContent=i+1;
  });
}

// ══════════════════════════════════════════════════════
// CHECKS
// ══════════════════════════════════════════════════════
function checkCode(){
  const len=curQ.codeLen||1;
  const val=Array.from({length:len},(_,i)=>(document.getElementById(`cb${i}`)||{value:''}).value.trim()).join('');
  if(val.length<len){showToast('מלאו את כל התיבות!');return;}
  val===curQ.answer ? onCorrect() : onWrong();
}

function checkChoice(idx){
  curQ.choices.forEach((_,i)=>{
    const b=document.getElementById(`ch${i}`);
    if(!b) return;
    b.disabled=true;
    if(i===curQ.correct) b.classList.add('correct');
    else if(i===idx) b.classList.add('wrong');
  });
  idx===curQ.correct ? onCorrect() : onWrong();
}

function checkText(){
  const inp=document.getElementById('ta');
  const val=(inp?inp.value:'').trim();
  if(!val){showToast('כתבו תשובה!');return;}
  if(inp) inp.disabled=true;
  const all=[curQ.answer,...(curQ.altAnswers||[])].map(a=>a.trim().toLowerCase());
  all.includes(val.toLowerCase()) ? onCorrect() : onWrong();
}

function checkOrder(){
  const list=document.getElementById('ord-list');
  if(!list) return;
  const curr=[...list.querySelectorAll('.order-item')].map(el=>el.dataset.id);
  JSON.stringify(curr)===JSON.stringify(curQ.correctOrder) ? onCorrect() : onWrong();
}

// ══════════════════════════════════════════════════════
// CORRECT / WRONG
// ══════════════════════════════════════════════════════
function onCorrect(){
  clearTimer();
  modalLocked=true;
  setFB('ok','✅ נכון! '+curQ.explanation);
  disableAll();
  const ar=document.getElementById('act-row');
  if(ar) ar.innerHTML=`<button class="btn btn-green" onclick="confirmOK()">▶ חזרו למפה</button>`;
}

function confirmOK(){
  completed.add(curIdx);
  modalLocked=false;
  closeModal();
  refreshPins();
  buildPaths();
  if(completed.size===6) setTimeout(winGame,500);
}

function onWrong(){
  lives--; wrongs++;
  buildLives();
  if(lives<=0){
    setFB('bad','💀 אין יותר חיים – הג\'ונגל ניצח!');
    disableAll(); clearTimer(); modalLocked=true;
    setTimeout(()=>{ closeModal(); loseGame(); },2000);
  } else {
    setFB('bad',`❌ לא נכון! נשארו ${lives} ❤️ – נסו שוב!`);
    setTimeout(()=>{ const fb=document.getElementById('fb'); if(fb) fb.className='feedback'; },2400);
  }
}

function setFB(cls,msg){
  const fb=document.getElementById('fb');
  if(fb){fb.className='feedback '+cls;fb.textContent=msg;}
}

function disableAll(){
  document.querySelectorAll('.choice-btn,.code-box,.text-ans').forEach(e=>e.disabled=true);
  document.querySelectorAll('.order-item').forEach(e=>{e.draggable=false;e.classList.add('disabled');});
}

// ══════════════════════════════════════════════════════
// TIMER
// ══════════════════════════════════════════════════════
function startTimer(sec){
  clearTimer();
  timerTotal=sec; timerLeft=sec;
  updateTimerUI();
  timerInt=setInterval(()=>{timerLeft--;updateTimerUI();if(timerLeft<=0){clearTimer();onWrong();}},1000);
}
function clearTimer(){clearInterval(timerInt);timerInt=null;}
function updateTimerUI(){
  const el=document.getElementById('tmr-num');
  if(!el) return;
  const m=Math.floor(timerLeft/60),s=timerLeft%60;
  el.textContent=`${m}:${s.toString().padStart(2,'0')}`;
  el.className='timer-num '+(timerLeft<=10?'danger':timerLeft<=25?'warn':'ok');
}

// ══════════════════════════════════════════════════════
// HINT
// ══════════════════════════════════════════════════════
function toggleHint(){
  const h=document.getElementById('hint-box');
  if(h) h.classList.toggle('show');
}

// ══════════════════════════════════════════════════════
// TEACHER ACTIONS
// ══════════════════════════════════════════════════════
function tCorrect(){ if(curIdx===null){showToast('פתחו אתגר קודם');return;} onCorrect(); }
function tWrong()  { if(curIdx===null){showToast('פתחו אתגר קודם');return;} onWrong(); }
function tSkip(){
  // find first uncompleted
  let idx=curIdx;
  if(idx===null){for(let i=0;i<6;i++){if(!completed.has(i)){idx=i;break;}}}
  if(idx===null) return;
  completed.add(idx);
  clearTimer(); modalLocked=false;
  document.getElementById('modal').classList.remove('open');
  refreshPins(); buildPaths();
  showToast('⏭️ אתגר נדלג!');
  if(completed.size===6) setTimeout(winGame,400);
}
function tAddLife(){ if(lives<5){lives++;buildLives();showToast('❤️ נוסף חיים!');} }
function tOpen(){
  for(let i=0;i<6;i++){ if(!completed.has(i)){openChallenge(i);return;} }
}

// ══════════════════════════════════════════════════════
// WIN / LOSE
// ══════════════════════════════════════════════════════
function winGame(){
  clearTimer();
  document.getElementById('tp').style.display='none';
  const e=Math.round((Date.now()-startTime)/1000);
  const m=Math.floor(e/60),s=e%60;
  document.getElementById('win-stats').innerHTML=`
    <div class="stat-row"><span class="stat-label">⏱️ זמן</span><span class="stat-val">${m}:${s.toString().padStart(2,'0')}</span></div>
    <div class="stat-row"><span class="stat-label">❌ טעויות</span><span class="stat-val">${wrongs}</span></div>
    <div class="stat-row"><span class="stat-label">❤️ נשאר</span><span class="stat-val">${lives}/3</span></div>
    <div class="stat-row"><span class="stat-label">🏆 דירוג</span><span class="stat-val">${wrongs===0?'⭐⭐⭐ מושלם!':wrongs<=2?'⭐⭐ מצוין!':wrongs<=5?'⭐ טוב!':'💪 אמיצים!'}</span></div>`;
  document.getElementById('s-win').classList.add('show');
  const p=document.getElementById('plane-el');
  p.style.animation='none';p.offsetHeight;p.style.animation='flyAcross 3s 0.4s cubic-bezier(.4,0,.2,1) both';
  launchConfetti();
}

function loseGame(){
  clearTimer();
  document.getElementById('tp').style.display='none';
  document.getElementById('s-lose').classList.add('show');
}

// ══════════════════════════════════════════════════════
// RESET
// ══════════════════════════════════════════════════════
function resetGame(){
  completed.clear(); lives=3; wrongs=0; startTime=null; curIdx=null; curQ=null;
  LOC_NAMES.forEach(n=>usedIndexes[n]=new Set());
  clearTimer(); modalLocked=false;
  document.getElementById('modal').classList.remove('open');
  document.getElementById('s-win').classList.remove('show');
  document.getElementById('s-lose').classList.remove('show');
  document.getElementById('tp').style.display='none';
  document.getElementById('s-intro').classList.remove('hidden');
}

// ══════════════════════════════════════════════════════
// UTILS
// ══════════════════════════════════════════════════════
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.style.opacity='1';
  clearTimeout(t._h);t._h=setTimeout(()=>t.style.opacity='0',2300);
}

function launchConfetti(){
  const cols=['#22c55e','#fcd34d','#38bdf8','#f97316','#a78bfa','#86efac','#fde68a'];
  for(let i=0;i<90;i++){
    setTimeout(()=>{
      const c=document.createElement('div');c.className='cp';
      const sz=5+Math.random()*9;
      c.style.cssText=`left:${Math.random()*100}vw;top:-12px;width:${sz}px;height:${sz}px;
        background:${cols[Math.floor(Math.random()*cols.length)]};
        border-radius:${Math.random()>.5?'50%':'2px'};
        --cx:${(Math.random()-.5)*320}px;
        animation-duration:${1.4+Math.random()*2.2}s;`;
      document.body.appendChild(c);
      setTimeout(()=>c.remove(),4000);
    },i*35);
  }
}
</script>
