<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🌴 בריחה מהג'ונגל</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Secular+One&family=Heebo:wght@300;400;600;700;800&display=swap');

:root {
  --bg:#061506;--surface:#0d230d;--surface2:#112811;--surface3:#183018;
  --green:#22c55e;--green2:#16a34a;--gold:#f59e0b;--gold2:#fcd34d;
  --red:#ef4444;--blue:#38bdf8;--purple:#a78bfa;
  --text:#e8f5e8;--muted:#4a7a4a;--border:#1a361a;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:'Heebo',sans-serif;background:var(--bg);color:var(--text);overflow:hidden;}

/* ══ INTRO ══ */
#s-intro{
  position:fixed;inset:0;z-index:200;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:radial-gradient(ellipse 80% 80% at 50% 50%, #0d2710 0%, #061506 100%);
  gap:0;padding:24px;
}
#s-intro.hidden{display:none;}

.intro-title{font-family:'Secular One',sans-serif;font-size:clamp(2.6rem,7vw,5rem);color:var(--green);
  text-shadow:0 0 50px rgba(34,197,94,0.6),0 3px 0 #000;
  animation:titlePop 0.9s cubic-bezier(.34,1.56,.64,1) both;line-height:1;}
.intro-sub{font-size:1rem;color:var(--muted);margin:10px 0 28px;animation:fadeUp 0.5s 0.3s ease both;}
.story-box{background:rgba(13,35,13,0.9);border:1px solid var(--border);border-radius:20px;
  padding:22px 30px;max-width:580px;width:100%;text-align:right;
  box-shadow:0 20px 60px rgba(0,0,0,0.6);animation:fadeUp 0.5s 0.4s ease both;margin-bottom:24px;}
.story-box p{font-size:0.97rem;line-height:1.8;color:#c8e8c8;}
.story-box p+p{margin-top:8px;}
.story-em{color:var(--gold2);font-weight:700;}

@keyframes titlePop{from{opacity:0;transform:scale(0.5);}to{opacity:1;transform:scale(1);}}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}

/* ══ WIN / LOSE ══ */
#s-win,#s-lose{
  position:fixed;inset:0;z-index:200;
  display:none;flex-direction:column;align-items:center;justify-content:center;
  background:rgba(6,21,6,0.97);gap:18px;text-align:center;padding:24px;
}
#s-win.show,#s-lose.show{display:flex;}

.win-title{font-family:'Secular One',sans-serif;font-size:clamp(2.4rem,6vw,4.5rem);color:var(--gold2);
  text-shadow:0 0 40px rgba(252,211,77,0.6);animation:titlePop 0.7s ease both;}
.lose-title{font-family:'Secular One',sans-serif;font-size:clamp(2rem,5vw,3.8rem);color:var(--red);
  text-shadow:0 0 30px rgba(239,68,68,0.5);animation:titlePop 0.6s ease both;}

.plane-scene{width:100%;max-width:560px;height:105px;position:relative;overflow:hidden;
  background:linear-gradient(180deg,#091628 0%,#1a3a5f 55%,#1a401a 100%);
  border-radius:16px;border:1px solid var(--border);}
.plane-el{position:absolute;font-size:2.6rem;animation:flyAcross 3s 0.4s cubic-bezier(.4,0,.2,1) both;}
@keyframes flyAcross{0%{left:-80px;top:62px;}40%{top:16px;}100%{left:calc(100% + 20px);top:8px;}}
.runway{position:absolute;bottom:0;left:0;right:0;height:30px;
  background:linear-gradient(180deg,#1a401a,#0d270d);
  display:flex;align-items:center;padding:0 16px;gap:8px;}
.runway-line{flex:1;height:2px;background:rgba(252,211,77,0.35);border-radius:2px;}
.runway-dot{width:6px;height:6px;background:var(--gold);border-radius:50%;animation:blink 0.5s ease infinite alternate;}
@keyframes blink{from{opacity:1;}to{opacity:0.15;}}

.win-stats{background:var(--surface);border:1px solid var(--border);border-radius:18px;
  padding:20px 30px;max-width:420px;width:100%;}
.stat-row{display:flex;justify-content:space-between;align-items:center;
  padding:7px 0;border-bottom:1px solid var(--border);}
.stat-row:last-child{border-bottom:none;}
.stat-label{color:var(--muted);font-size:0.88rem;}
.stat-val{font-weight:800;color:var(--gold2);}

/* ══════════════════════════════════════
   FULLSCREEN MAP
══════════════════════════════════════ */
#map-wrap{
  position:fixed;inset:0;z-index:1;
  /* jungle background – layered gradients + texture */
  background:
    radial-gradient(ellipse 60% 50% at 20% 80%, #0f3010 0%, transparent 55%),
    radial-gradient(ellipse 50% 60% at 80% 20%, #0d2a0d 0%, transparent 55%),
    radial-gradient(ellipse 70% 70% at 50% 50%, #102810 0%, #061506 100%);
  overflow:hidden;
}

/* animated light rays */
#map-wrap::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:
    conic-gradient(from 200deg at 15% 10%, transparent 0deg, rgba(34,197,94,0.04) 20deg, transparent 40deg),
    conic-gradient(from 20deg at 85% 90%, transparent 0deg, rgba(34,197,94,0.03) 25deg, transparent 50deg);
  animation:rays 8s ease-in-out infinite alternate;
}
@keyframes rays{from{opacity:0.5;}to{opacity:1;}}

/* fog patches */
#map-wrap::after{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:
    radial-gradient(ellipse 30% 20% at 10% 50%, rgba(34,197,94,0.05) 0%, transparent 70%),
    radial-gradient(ellipse 25% 15% at 90% 60%, rgba(34,197,94,0.04) 0%, transparent 70%),
    radial-gradient(ellipse 20% 10% at 50% 10%, rgba(255,255,255,0.02) 0%, transparent 70%);
  animation:fog 12s ease-in-out infinite alternate;
}
@keyframes fog{from{transform:translateX(-10px);}to{transform:translateX(10px);}}

/* fireflies */
.fly{position:fixed;border-radius:50%;pointer-events:none;z-index:2;animation:flyMove linear infinite;}
@keyframes flyMove{0%{opacity:0;transform:translate(0,0);}20%{opacity:1;}80%{opacity:0.8;}100%{opacity:0;transform:translate(var(--dx),var(--dy));}}

/* SVG for paths */
#map-svg{position:absolute;inset:0;width:100%;height:100%;z-index:3;pointer-events:none;}
.map-path{stroke:#2d5a2d;stroke-width:3;stroke-dasharray:10 6;fill:none;opacity:0.5;
  filter:drop-shadow(0 0 3px rgba(34,197,94,0.2));}
.map-path-done{stroke:var(--green);stroke-width:4;stroke-dasharray:none;opacity:0.7;
  filter:drop-shadow(0 0 6px rgba(34,197,94,0.5));}

/* decorative emojis on map */
.map-deco{position:absolute;z-index:4;pointer-events:none;font-size:1.6rem;opacity:0.55;
  animation:decoFloat ease-in-out infinite alternate;}
@keyframes decoFloat{from{transform:translateY(0) rotate(-3deg);}to{transform:translateY(-6px) rotate(3deg);}}

/* HUD overlay at top */
.map-hud{
  position:absolute;top:0;left:0;right:0;z-index:10;
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 20px;
  background:linear-gradient(180deg, rgba(6,21,6,0.92) 0%, transparent 100%);
}
.hud-title{font-family:'Secular One',sans-serif;font-size:1.5rem;color:var(--green);
  text-shadow:0 0 20px rgba(34,197,94,0.5);}
.hud-right{display:flex;align-items:center;gap:14px;}
.hud-lives{display:flex;gap:5px;}
.life{font-size:1.2rem;transition:all 0.3s;}
.life.lost{opacity:0.15;filter:grayscale(1);}
.hud-prog-wrap{display:flex;align-items:center;gap:8px;
  background:rgba(13,35,13,0.8);border:1px solid var(--border);border-radius:20px;padding:6px 14px;}
.hud-prog-track{width:100px;height:8px;background:rgba(255,255,255,0.1);border-radius:99px;overflow:hidden;}
.hud-prog-fill{height:100%;background:linear-gradient(90deg,var(--green2),var(--green));
  border-radius:99px;transition:width 0.8s ease;}
.hud-prog-pct{font-size:0.78rem;font-weight:800;color:var(--green);min-width:28px;}

/* LOCATION PINS */
.map-loc{
  position:absolute;z-index:8;
  transform:translate(-50%,-50%);
  cursor:pointer;
  display:flex;flex-direction:column;align-items:center;gap:5px;
  transition:transform 0.2s;
}
.map-loc:hover .loc-bubble{transform:scale(1.1);}

.loc-bubble{
  width:62px;height:62px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:1.6rem;
  position:relative;
  transition:all 0.25s;
  filter:drop-shadow(0 4px 12px rgba(0,0,0,0.6));
}

/* state styles */
.map-loc.locked .loc-bubble{
  background:radial-gradient(circle, #1a2a1a, #0d1a0d);
  border:2px solid #2a3a2a;filter:grayscale(0.8) brightness(0.6);cursor:not-allowed;
}
.map-loc.available .loc-bubble{
  background:radial-gradient(circle, #2a3a10, #1a2a08);
  border:3px solid var(--gold);
  animation:availPulse 1.8s ease-in-out infinite;
  cursor:pointer;
}
@keyframes availPulse{
  0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,0.5),0 4px 20px rgba(0,0,0,0.5);}
  50%{box-shadow:0 0 0 12px rgba(245,158,11,0),0 4px 20px rgba(0,0,0,0.5);}
}
.map-loc.done .loc-bubble{
  background:radial-gradient(circle, #14532d, #0d3320);
  border:3px solid var(--green);
  box-shadow:0 0 20px rgba(34,197,94,0.4);
}
.map-loc.current .loc-bubble{
  background:radial-gradient(circle, #1e3a5f, #0f2040);
  border:3px solid var(--blue);
  animation:availPulse2 1.2s ease-in-out infinite;
}
@keyframes availPulse2{
  0%,100%{box-shadow:0 0 0 0 rgba(56,189,248,0.5);}
  50%{box-shadow:0 0 0 14px rgba(56,189,248,0);}
}

.done-badge{position:absolute;top:-3px;right:-3px;background:var(--green);
  border-radius:50%;width:20px;height:20px;display:flex;align-items:center;
  justify-content:center;font-size:0.65rem;font-weight:900;border:2px solid var(--bg);color:#fff;}
.lock-badge{position:absolute;top:-3px;right:-3px;font-size:0.85rem;}

.loc-label{
  background:rgba(6,21,6,0.88);border:1px solid rgba(34,197,94,0.2);
  border-radius:8px;padding:3px 9px;font-size:0.72rem;font-weight:700;
  color:var(--text);white-space:nowrap;backdrop-filter:blur(6px);
  text-shadow:0 1px 3px rgba(0,0,0,0.8);
}
.map-loc.done .loc-label{color:var(--green);border-color:rgba(34,197,94,0.4);}
.map-loc.available .loc-label{color:var(--gold2);border-color:rgba(245,158,11,0.4);}

/* challenge number badge */
.loc-num{
  position:absolute;bottom:-3px;left:-3px;
  background:rgba(6,21,6,0.9);border:1px solid var(--border);
  border-radius:50%;width:18px;height:18px;
  display:flex;align-items:center;justify-content:center;
  font-size:0.6rem;font-weight:900;color:var(--muted);
}

/* ══ CHALLENGE MODAL ══ */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:100;
  display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(8px);padding:16px;
}
.modal-overlay.open{display:flex;}

.challenge-modal{
  background:var(--surface);border:1px solid var(--border);
  border-radius:24px;width:100%;max-width:600px;
  max-height:90vh;overflow-y:auto;
  box-shadow:0 32px 80px rgba(0,0,0,0.7),0 0 0 1px rgba(34,197,94,0.05);
  animation:modalIn 0.4s cubic-bezier(.34,1.3,.64,1) both;
  position:relative;
}
@keyframes modalIn{from{opacity:0;transform:scale(0.85) translateY(24px);}to{opacity:1;transform:scale(1) translateY(0);}}

.modal-topbar{height:5px;border-radius:24px 24px 0 0;overflow:hidden;}
.modal-topbar-fill{height:100%;background:linear-gradient(90deg,var(--green2),var(--green));transition:width 1s linear;}

.modal-inner{padding:28px 32px;}

.modal-close{position:absolute;top:14px;left:14px;z-index:10;
  background:var(--surface2);border:1px solid var(--border);border-radius:8px;
  width:30px;height:30px;display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--muted);font-size:0.9rem;transition:all 0.2s;}
.modal-close:hover{border-color:var(--red);color:var(--red);}

.modal-timer-display{
  display:none;align-items:center;justify-content:center;gap:6px;
  background:var(--surface2);border:1px solid var(--border);border-radius:20px;
  padding:5px 14px;margin-bottom:14px;
}
.modal-timer-display.show{display:flex;}
.timer-num{font-size:1.05rem;font-weight:800;font-variant-numeric:tabular-nums;}
.timer-num.ok{color:var(--green);}
.timer-num.warn{color:var(--gold);}
.timer-num.danger{color:var(--red);animation:tpulse 0.3s ease infinite alternate;}
@keyframes tpulse{from{opacity:1;}to{opacity:0.3;}}

.ch-icon{font-size:2.6rem;text-align:center;display:block;margin-bottom:6px;}
.ch-type{font-size:0.7rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);text-align:center;margin-bottom:4px;}
.ch-title{font-family:'Secular One',sans-serif;font-size:1.55rem;color:var(--gold2);text-align:center;margin-bottom:16px;}
.ch-desc{font-size:0.96rem;line-height:1.75;color:#c8e8c8;background:var(--surface2);
  border-radius:12px;padding:14px 17px;border:1px solid var(--border);margin-bottom:16px;text-align:right;}
.ch-desc strong{color:var(--gold2);}

/* choices */
.choices{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;}
.choice-btn{background:var(--surface2);border:2px solid var(--border);border-radius:11px;
  padding:13px 15px;font-family:'Heebo',sans-serif;font-size:0.9rem;font-weight:600;
  color:var(--text);cursor:pointer;text-align:right;transition:all 0.18s;line-height:1.4;}
.choice-btn:not(:disabled):hover{border-color:var(--green);background:var(--surface3);color:var(--green);}
.choice-btn.correct{border-color:var(--green)!important;background:rgba(34,197,94,0.15)!important;color:var(--green)!important;}
.choice-btn.wrong{border-color:var(--red)!important;background:rgba(239,68,68,0.1)!important;color:var(--red)!important;}

/* code */
.code-row{display:flex;gap:10px;margin-bottom:16px;justify-content:center;flex-wrap:wrap;}
.code-box{width:62px;height:70px;background:var(--surface2);border:2px solid var(--border);
  border-radius:12px;font-size:1.8rem;font-weight:800;font-family:'Secular One',sans-serif;
  color:var(--gold2);text-align:center;outline:none;transition:border-color 0.2s,box-shadow 0.2s;}
.code-box:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(245,158,11,0.2);}

/* text */
.text-wrap{display:flex;gap:9px;margin-bottom:16px;}
.text-ans{flex:1;background:var(--surface2);border:2px solid var(--border);border-radius:11px;
  padding:12px 15px;font-size:1rem;font-family:'Heebo',sans-serif;color:var(--text);
  outline:none;text-align:right;transition:border-color 0.2s,box-shadow 0.2s;}
.text-ans:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(34,197,94,0.15);}

/* order */
.order-list{display:flex;flex-direction:column;gap:7px;margin-bottom:16px;}
.order-item{background:var(--surface2);border:2px solid var(--border);border-radius:10px;
  padding:11px 14px;font-size:0.9rem;font-weight:600;cursor:grab;
  display:flex;align-items:center;gap:10px;transition:all 0.2s;user-select:none;}
.order-item:not(.disabled):hover{border-color:var(--green);background:var(--surface3);}
.order-item.dragging{opacity:0.3;border-color:var(--gold);}
.order-item.drag-over{border-color:var(--green);background:rgba(34,197,94,0.1);}
.order-item.disabled{cursor:default;}
.drag-handle{color:var(--muted);}
.ord-num{background:var(--surface3);border:1px solid var(--border);border-radius:5px;
  width:22px;height:22px;display:flex;align-items:center;justify-content:center;
  font-size:0.72rem;font-weight:800;color:var(--green);flex-shrink:0;}

/* clues */
.clues-list{display:flex;flex-direction:column;gap:6px;margin-bottom:14px;}
.clue-item{display:flex;align-items:flex-start;gap:9px;background:var(--surface2);
  border:1px solid var(--border);border-radius:9px;padding:9px 13px;}
.clue-n{background:var(--green2);color:#fff;border-radius:50%;width:20px;height:20px;
  display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:800;flex-shrink:0;}
.clue-t{font-size:0.88rem;line-height:1.5;color:#c8e8c8;}

/* feedback */
.feedback{display:none;border-radius:11px;padding:12px 16px;margin-bottom:14px;
  font-size:0.93rem;font-weight:600;text-align:center;line-height:1.4;}
.feedback.ok{display:block;background:rgba(34,197,94,0.14);border:1px solid var(--green);color:var(--green);}
.feedback.bad{display:block;background:rgba(239,68,68,0.1);border:1px solid var(--red);color:var(--red);}

.hint-box{background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.25);
  border-radius:9px;padding:9px 13px;font-size:0.82rem;color:var(--gold2);margin-bottom:14px;display:none;}
.hint-box.show{display:block;}

.action-row{display:flex;gap:9px;justify-content:center;flex-wrap:wrap;}

/* BUTTONS */
.btn{border:none;border-radius:11px;padding:12px 26px;font-family:'Heebo',sans-serif;
  font-size:0.95rem;font-weight:700;cursor:pointer;transition:all 0.17s;box-shadow:0 3px 12px rgba(0,0,0,0.3);}
.btn-green{background:linear-gradient(135deg,#15803d,#22c55e);color:#fff;}
.btn-green:hover{transform:translateY(-2px);box-shadow:0 7px 20px rgba(34,197,94,0.4);}
.btn-gold{background:linear-gradient(135deg,#b45309,#f59e0b);color:#000;}
.btn-gold:hover{transform:translateY(-2px);}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--muted);}
.btn-ghost:hover{border-color:var(--green);color:var(--green);}
.btn:active{transform:scale(0.97);}
.btn-xl{font-size:1.15rem;padding:16px 44px;border-radius:14px;}

/* TEACHER PANEL */
.teacher-panel{position:fixed;bottom:0;left:0;right:0;z-index:150;
  background:rgba(6,21,6,0.97);border-top:1px solid var(--border);backdrop-filter:blur(14px);
  padding:8px 16px;display:none;align-items:center;gap:8px;flex-wrap:wrap;}
.tp-lbl{font-size:0.7rem;color:var(--muted);font-weight:800;text-transform:uppercase;letter-spacing:0.06em;white-space:nowrap;}
.tp-btn{background:var(--surface2);border:1px solid var(--border);border-radius:7px;
  padding:6px 11px;font-family:'Heebo',sans-serif;font-size:0.76rem;font-weight:700;
  color:var(--text);cursor:pointer;transition:all 0.18s;white-space:nowrap;}
.tp-btn:hover{border-color:var(--green);color:var(--green);}
.tp-btn.d:hover{border-color:var(--red);color:var(--red);}
.tp-sep{width:1px;height:20px;background:var(--border);flex-shrink:0;}

/* confetti */
.cp{position:fixed;pointer-events:none;z-index:300;animation:cfFall linear forwards;}
@keyframes cfFall{0%{opacity:1;transform:translate(0,0) rotate(0);}100%{opacity:0;transform:translate(var(--cx),100vh) rotate(720deg);}}

#toast{position:fixed;top:74px;left:50%;transform:translateX(-50%);
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  padding:9px 20px;font-size:0.87rem;font-weight:700;z-index:400;
  box-shadow:0 4px 20px rgba(0,0,0,0.5);transition:opacity 0.3s;opacity:0;pointer-events:none;}

@media(max-width:560px){
  .choices{grid-template-columns:1fr;}
  .modal-inner{padding:20px 16px;}
  .code-box{width:50px;height:60px;font-size:1.5rem;}
}
</style>
</head>
<body>

<!-- fireflies -->
<script>
for(let i=0;i<22;i++){
  const f=document.createElement('div');f.className='fly';
  const s=1.5+Math.random()*3.5;
  const c=['#22c55e','#86efac','#fcd34d','#fde68a','#a7f3d0'][Math.floor(Math.random()*5)];
  f.style.cssText=`width:${s}px;height:${s}px;background:${c};left:${Math.random()*100}vw;top:${Math.random()*100}vh;--dx:${(Math.random()-.5)*250}px;--dy:${(Math.random()-.5)*250}px;animation-duration:${3+Math.random()*7}s;animation-delay:${Math.random()*6}s;box-shadow:0 0 5px ${c};`;
  document.body.appendChild(f);
}
</script>

<div id="toast"></div>

<!-- ══ INTRO ══ -->
<div id="s-intro">
  <div class="intro-title">🌴 בריחה מהג'ונגל</div>
  <div class="intro-sub">משחק כיתתי – כולכם יחד נגד הג'ונגל!</div>
